.DS_Store
__pycache__/
*.py[cod]

# Generated CSV exports are reproducible from the scripts.
*.csv

# Batch-rendered script images are generated beside source JSON files.
all_jsons/**/*.jpg
all_jsons/**/*.jpeg

# Node/Vite outputs.
script_editor/node_modules/
script_editor/dist/
script_editor/.vite/

# User-created app data should stay local.
script_editor/public/custom/*.json
script_editor/public/custom/**/*.json

# Tauri/Rust build outputs.
script_editor/src-tauri/target/

# Local environment files.
.env
.env.*
